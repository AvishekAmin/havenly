<% layout("/layouts/boilerplate") %>

<!-- ===== BOOKING CONFIRMATION & PAYMENT MOCKUP ===== -->
<div class="container py-5 reveal">
    <div class="row g-5">
        
        <!-- ===== LEFT COLUMN: PAYMENT FORM ===== -->
        <div class="col-lg-7">
            <a href="/listings/<%= listing._id %>" class="btn btn-glass btn-sm mb-4">
                <i class="fa-solid fa-chevron-left me-1"></i> Back to Listing
            </a>

            <h2 class="mb-4 text-primary-glow">Confirm and Pay</h2>

            <!-- Trip summary (Selected from query params) -->
            <div class="show-info-card mb-4">
                <h4><i class="fa-solid fa-calendar-check" style="color: #00D8FF;"></i> Trip Details</h4>
                <div class="row mt-3">
                    <div class="col-sm-6 mb-2">
                        <span class="text-muted d-block" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700;">Dates</span>
                        <span id="payment-dates-val" class="fw-semibold">Loading dates...</span>
                    </div>
                    <div class="col-sm-6 mb-2">
                        <span class="text-muted d-block" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700;">Guests</span>
                        <span id="payment-guests-val" class="fw-semibold">1 guest</span>
                    </div>
                </div>
            </div>

            <!-- Payment Method Card -->
            <div class="show-info-card mb-4">
                <h4><i class="fa-solid fa-credit-card" style="color: #00D8FF;"></i> Payment Method</h4>
                
                <div class="d-flex gap-3 my-3">
                    <div class="form-check p-3 rounded border border-secondary flex-fill cursor-pointer" style="background: rgba(255,255,255,0.02);">
                        <input class="form-check-input ms-0 me-2" type="radio" name="paymentMethod" id="payCard" checked>
                        <label class="form-check-label fw-bold cursor-pointer" for="payCard">Credit / Debit Card</label>
                    </div>
                    <div class="form-check p-3 rounded border border-secondary flex-fill cursor-pointer" style="background: rgba(255,255,255,0.02); opacity: 0.6;">
                        <input class="form-check-input ms-0 me-2" type="radio" name="paymentMethod" id="payUPI" disabled>
                        <label class="form-check-label fw-bold cursor-pointer" for="payUPI">UPI / Net Banking</label>
                    </div>
                </div>

                <!-- Mockup Card Details Form -->
                <form id="payment-form" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size: 0.82rem; font-weight: 600;">Cardholder Name</label>
                        <input type="text" class="form-control form-control-dark" required placeholder="Avishek Amin">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size: 0.82rem; font-weight: 600;">Card Number</label>
                        <input type="text" class="form-control form-control-dark" required placeholder="4111 2222 3333 4444" pattern="\d{16}" title="16-digit card number">
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted" style="font-size: 0.82rem; font-weight: 600;">Expiration</label>
                            <input type="text" class="form-control form-control-dark" required placeholder="MM/YY" pattern="\d{2}/\d{2}" title="MM/YY format">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted" style="font-size: 0.82rem; font-weight: 600;">CVV</label>
                            <input type="password" class="form-control form-control-dark" required placeholder="123" pattern="\d{3}" title="3-digit CVV number">
                        </div>
                    </div>

                    <button class="btn btn-reserve-glow w-100 py-3 mt-3 fw-bold" type="submit">Confirm Reservation</button>
                </form>
            </div>
        </div>

        <!-- ===== RIGHT COLUMN: BILL BREAKDOWN ===== -->
        <div class="col-lg-5">
            <div class="show-info-card sticky-top" style="top: 5.8rem;">
                
                <!-- Listing summary card -->
                <div class="d-flex gap-3 align-items-center mb-4">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" style="width: 100px; height: 75px; object-fit: cover; border-radius: var(--radius-md); border: 1px solid rgba(0, 216, 255, 0.15);">
                    <div>
                        <h5 class="mb-1 text-truncate" style="max-width: 250px;"><%= listing.title %></h5>
                        <p class="text-muted mb-0" style="font-size: 0.82rem;"><i class="fa-solid fa-location-dot me-1"></i> <%= listing.location %>, <%= listing.country %></p>
                        <span style="font-size: 0.8rem; color: var(--accent);"><i class="fa-solid fa-star me-1"></i> 4.8</span>
                    </div>
                </div>

                <hr style="opacity: 0.1;">

                <!-- Price Details -->
                <h4 class="mb-3">Price Details</h4>
                <div class="d-flex justify-content-between mb-2">
                    <span id="rate-breakdown-text" class="text-muted">&#8377; <%= listing.price.toLocaleString("en-IN") %> x 0 nights</span>
                    <span id="base-price-val" class="fw-semibold">&#8377; 0</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">GST (18%)</span>
                    <span id="gst-val" class="fw-semibold">&#8377; 0</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Service Fee</span>
                    <span class="fw-semibold text-success">Free</span>
                </div>

                <hr style="opacity: 0.1;">

                <!-- Total Amount -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fw-bold" style="font-size: 1.1rem;">Total (INR)</span>
                    <span id="total-amount-val" class="fw-bold text-primary-glow" style="font-size: 1.3rem;">&#8377; 0</span>
                </div>

                <div class="p-3 rounded" style="background: rgba(0, 216, 255, 0.05); border: 1px solid rgba(0, 216, 255, 0.15);">
                    <p class="mb-0 text-muted" style="font-size: 0.78rem; line-height: 1.45;">
                        <i class="fa-solid fa-circle-info text-primary-glow me-1"></i>
                        <strong>Havenly Guarantee:</strong> Your funds will be securely held and only transferred to the host after your check-in.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== PAGE LOGIC AND FORM SUBMISSION ===== -->
<script>
(function initPaymentPage() {
    const urlParams = new URLSearchParams(window.location.search);
    const checkInStr = urlParams.get('checkIn');
    const checkOutStr = urlParams.get('checkOut');
    const guestsStr = urlParams.get('guests') || '1 guest';

    const datesVal = document.getElementById('payment-dates-val');
    const guestsVal = document.getElementById('payment-guests-val');

    const rateBreakdown = document.getElementById('rate-breakdown-text');
    const basePriceVal = document.getElementById('base-price-val');
    const gstVal = document.getElementById('gst-val');
    const totalVal = document.getElementById('total-amount-val');

    const listingPrice = <%= listing.price %>;

    if (checkInStr && checkOutStr) {
        if (datesVal) datesVal.textContent = `${checkInStr} – ${checkOutStr}`;
        if (guestsVal) guestsVal.textContent = guestsStr;

        // Parse days to calculate nights
        const startDay = parseInt(checkInStr.split(' ')[0]);
        const endDay = parseInt(checkOutStr.split(' ')[0]);
        const nights = endDay - startDay;

        if (nights > 0) {
            const baseTotal = listingPrice * nights;
            const gst = baseTotal * 0.18;
            const grandTotal = baseTotal + gst;

            if (rateBreakdown) rateBreakdown.textContent = `₹ ${listingPrice.toLocaleString("en-IN")} x ${nights} night${nights > 1 ? 's' : ''}`;
            if (basePriceVal) basePriceVal.innerHTML = `&#8377; ${baseTotal.toLocaleString("en-IN")}`;
            if (gstVal) gstVal.innerHTML = `&#8377; ${gst.toLocaleString("en-IN")}`;
            if (totalVal) totalVal.innerHTML = `&#8377; ${grandTotal.toLocaleString("en-IN")}`;
        }
    } else {
        // Default to 1 night if no query params passed
        if (datesVal) datesVal.textContent = "Dates not selected";
        const baseTotal = listingPrice;
        const gst = baseTotal * 0.18;
        const grandTotal = baseTotal + gst;

        if (rateBreakdown) rateBreakdown.textContent = `₹ ${listingPrice.toLocaleString("en-IN")} x 1 night`;
        if (basePriceVal) basePriceVal.innerHTML = `&#8377; ${baseTotal.toLocaleString("en-IN")}`;
        if (gstVal) gstVal.innerHTML = `&#8377; ${gst.toLocaleString("en-IN")}`;
        if (totalVal) totalVal.innerHTML = `&#8377; ${grandTotal.toLocaleString("en-IN")}`;
    }

    // Form Submission Mockup
    const form = document.getElementById('payment-form');
    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            if (!form.checkValidity()) {
                e.stopPropagation();
                form.classList.add('was-validated');
                return;
            }

            // Create and trigger a custom confirmation popup
            showSuccessNotification("Booking Confirmed! redirecting...");
            
            setTimeout(() => {
                window.location.href = "/listings";
            }, 3000);
        });
    }

    function showSuccessNotification(message) {
        let container = document.getElementById('notification-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'notification-container';
            document.body.appendChild(container);
        }

        const notification = document.createElement('div');
        notification.className = 'toast-notification';
        notification.innerHTML = `
            <div class="toast-content">
                <i class="fa-solid fa-circle-check toast-icon toast-icon-success"></i>
                <span class="toast-message">${message}</span>
            </div>
        `;
        container.appendChild(notification);

        setTimeout(() => {
            notification.classList.add('show');
        }, 10);

        setTimeout(() => {
            notification.classList.remove('show');
            notification.classList.add('hide');
            setTimeout(() => {
                notification.remove();
            }, 400);
        }, 3000);
    }
})();
</script>
